{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "module": "esnext",
    "moduleResolution": "node10",
    "paths": {
      "@moveee/utils/*": ["../../packages/utils/*"],
      "react": ["./node_modules/@types/react"],
      "react/*": ["./node_modules/@types/react/*"]
    },
    "types": ["react"]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ]
}
