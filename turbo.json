{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "NEXTAUTH_SECRET",
        "NEXTAUTH_URL",
        "CULTURE_API_SECRET",
        "GEMINI_API_KEY",
        "CRON_SECRET",
        "VERTEX_PROJECT",
        "VERTEX_LOCATION",
        "VERTEX_CLIENT_EMAIL",
        "VERTEX_PRIVATE_KEY",
        "WP_APP_PASSWORD",
        "WP_USERNAME",
        "WP_APP_USER",
        "WP_APP_PASS",
        "PULSE_REFRESH_SECRET",
        "SERPER_API_KEY",
        "WC_CONSUMER_KEY",
        "WC_CONSUMER_SECRET",
        "WP_REVALIDATE_SECRET",
        "KV_REST_API_URL",
        "KV_REST_API_TOKEN",
        "KV_REST_API_READ_ONLY_TOKEN",
        "KV_URL",
        "REDIS_URL",
        "R2_ACCESS_KEY_ID",
        "R2_SECRET_ACCESS_KEY",
        "R2_BUCKET_NAME",
        "R2_ACCOUNT_ID",
        "R2_PUBLIC_URL",
        "NEXT_PUBLIC_SITE_URL",
        "NEXT_PUBLIC_WP_URL",
        "NEXT_PUBLIC_CONNECT_URL"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    }
  }
}
