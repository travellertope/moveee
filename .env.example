# Moveee Platform - Environment Configuration

# WordPress GraphQL Endpoint (Public)
NEXT_PUBLIC_WORDPRESS_API_URL=https://themoveee.com/graphql

# WordPress Site URL (for SEO and relative links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Revalidation Secret (for ISR on-demand - optional)
# REVALIDATION_SECRET=your_secret_here

# ── Moveee Pulse ────────────────────────────────────────────────────────────
#
# WordPress REST API credentials (for Pulse story write operations).
# Generate an Application Password: WP Admin → Users → Profile → Application Passwords
WP_USERNAME=your_wp_username
WP_APP_PASSWORD=your_wp_application_password

# Secret used to protect the /api/pulse/refresh endpoint and the Pulse admin UI.
# Generate with: openssl rand -hex 32
PULSE_REFRESH_SECRET=a_random_secret_string_for_cron_security